{% if business.services.length > 0 %}
  <section id="services">
    <h2>Our Primary Services</h2>
    <div class="services-grid">
      {% for service in business.services %}
        {% if service.label and service.body %}
          <div class="service-card">
            <div class="service-header">
              <svg viewBox="0 0 16 16" fill="none" class="icon-check" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M16 8C16 12.4183 12.4183 16 8 16C3.58172 16 0 12.4183 0 8C0 3.58172 3.58172 0 8 0C12.4183 0 16 3.58172 16 8ZM11.5303
                    6.53033L12.0607 6L11 4.93934L10.4697 5.46967L6.5 9.43934L5.53033 8.46967L5 7.93934L3.93934 9L4.46967 9.53033L5.96967
                    11.0303C6.26256 11.3232 6.73744 11.3232 7.03033 11.0303L11.5303 6.53033Z"
                  fill="currentColor"></path>
              </svg>
              <h3>{{ service.label }}</h3>
            </div>
            <p>{{ service.body }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}