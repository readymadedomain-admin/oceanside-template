{% if business.reviews.length > 0 %}
  <section id="reviews">
    <h2>What Our Clients Say</h2>
    <div class="carousel">
      {% for review in business.reviews %}
        {% if review.quote and review.author %}
          <blockquote class="review-card">
            <div class="review">
              <div class="rating">
                <svg height="16" stroke-linejoin="round" viewBox="0 0 16 16" width="16" style="color: currentcolor;">
                  <path
                    d="M7.99999 0.489502L10.5734 5.20807L15.8562 6.19736L12.1638 10.1029L12.8554 15.4329L7.99999 13.1281L3.1446
                      15.4329L3.83621 10.1029L0.143799 6.19736L5.42663 5.20807L7.99999 0.489502Z"
                    fill="currentColor"></path>
                </svg>
                <svg height="16" stroke-linejoin="round" viewBox="0 0 16 16" width="16" style="color: currentcolor;">
                  <path
                    d="M7.99999 0.489502L10.5734 5.20807L15.8562 6.19736L12.1638 10.1029L12.8554 15.4329L7.99999 13.1281L3.1446
                      15.4329L3.83621 10.1029L0.143799 6.19736L5.42663 5.20807L7.99999 0.489502Z"
                    fill="currentColor"></path>
                </svg>
                <svg height="16" stroke-linejoin="round" viewBox="0 0 16 16" width="16" style="color: currentcolor;">
                  <path
                    d="M7.99999 0.489502L10.5734 5.20807L15.8562 6.19736L12.1638 10.1029L12.8554 15.4329L7.99999 13.1281L3.1446
                      15.4329L3.83621 10.1029L0.143799 6.19736L5.42663 5.20807L7.99999 0.489502Z"
                    fill="currentColor"></path>
                </svg>
                <svg height="16" stroke-linejoin="round" viewBox="0 0 16 16" width="16" style="color: currentcolor;">
                  <path
                    d="M7.99999 0.489502L10.5734 5.20807L15.8562 6.19736L12.1638 10.1029L12.8554 15.4329L7.99999 13.1281L3.1446
                      15.4329L3.83621 10.1029L0.143799 6.19736L5.42663 5.20807L7.99999 0.489502Z"
                    fill="currentColor"></path>
                </svg>
                <svg height="16" stroke-linejoin="round" viewBox="0 0 16 16" width="16" style="color: currentcolor;">
                  <path
                    d="M7.99999 0.489502L10.5734 5.20807L15.8562 6.19736L12.1638 10.1029L12.8554 15.4329L7.99999 13.1281L3.1446
                      15.4329L3.83621 10.1029L0.143799 6.19736L5.42663 5.20807L7.99999 0.489502Z"
                    fill="currentColor"></path>
                </svg>
              </div>
              <p class="review-quote">“{{ review.quote }}”</p>
            </div>
            <cite class="review-author">— {{ review.author }}</cite>
          </blockquote>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}