{% if business.about.body %}
  <section id="about">
    {% if business.about.image %}
      <div class="about-image">
        <img src="{{ business.about.image }}" alt="About {{ business.meta.businessName }}" loading="lazy"></div>
      {% endif %}
      <div class="about-container">
        <div class="about-content">
          <h2>{{ business.about.headline | default("Our Story", true) }}</h2>
          <p>{{ business.about.body }}</p>
        </div>

        {% set contact = business.meta.primaryContact %}
        {% if "@" in contact %}
          {% set url = "mailto:" + contact %}
        {% elif contact %}
          {# This chain handles spaces, dashes, dots, and parentheses #}
          {% set cleanedPhone = contact | replace(" ", "") | replace("-", "") | replace(".", "") | replace("(", "") | replace(")", "") %}
          {% set url = "tel:" + cleanedPhone %}
        {% else %}
          {% set url = "#contact" %}
        {% endif %}
        <a href="{{ url }}" class="btn-secondary">
          {{ business.header.ctaText }}
        </a>
        
      </div>
    </section>
  {% endif %}